{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "allowJs": true,
        "baseUrl": "./src",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "incremental": true,
        "isolatedModules": true,
        "lib": [
            "DOM",
            "ESNext"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "noImplicitAny": true,
        "paths": {
            "~/*": [
                "./*"
            ]
        },
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ESNext",
        "tsBuildInfoFile": ".tsbuildinfo",
        "types": [
            "vite/client"
        ]
    },
    "exclude": [
        "node_modules/"
    ],
    "include": [
        "*.config.ts",
        ".husky/install.js",
        "src/"
    ]
}
